# ============================================================================
# ROS2 / colcon 构建产物
# ============================================================================
# colcon build 一跑就会生成这三个目录，每个可能上百 MB，且完全可重新生成。
build/
install/
log/
.colcon/
compile_commands.json

# ament_python 的 setup.py 会生成 egg-info。
# 注意：本仓库里 egg-info 曾被误提交，只加 ignore 规则救不了已跟踪的文件，
# 必须先 `git rm -r --cached`（见文末说明）。
*.egg-info/
*.egg
.eggs/

# ============================================================================
# ROS2 运行时数据
# ============================================================================
# rosbag 动辄几个 GB，绝不该进 git。
*.bag
*.db3
*.mcap
rosbag2_*/

# 控制器 output_recorder 写出的记录（Excel / 中间 CSV）
record/
records/
*.xlsx
*.tmp.csv

# ============================================================================
# Python
# ============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyd

# 虚拟环境。venv 会自己在目录里塞一个 .gitignore，但换成 conda / uv / poetry
# 就不会了，所以这里显式再挡一道。
.venv/
.venv*/
venv/
env/
ENV/
.conda/
.python-version

# 打包 / 测试 / 静态检查缓存
dist/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.coverage
.coverage.*
htmlcov/
coverage.xml

# ============================================================================
# 机器学习产物（terragrip_vla/ 内另有一份更贴近该项目的规则）
# ============================================================================
# 权重、特征缓存、数据集：体积大，且都能由固定种子完整重建，不进版本库。
*.pt
*.pth
*.ckpt
*.onnx
*.npz
*.npy

# 实验跟踪与配置框架的输出
wandb/
runs/
lightning_logs/
outputs/      # hydra 默认输出目录
multirun/     # hydra sweep 输出
.hydra/

# ============================================================================
# 归档 / 快照
# ============================================================================
# 本仓库里的 zip 是代码快照备份（src/无解.zip 等），不是源码。
*.zip
*.tar
*.tar.gz
*.tgz
*.7z

# ============================================================================
# 编辑器 / 操作系统
# ============================================================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ============================================================================
# 机密
# ============================================================================
# 不要提交 API key（wandb / HuggingFace token 等）。
.env
.env.*
*.key
*.pem
secrets.yaml
